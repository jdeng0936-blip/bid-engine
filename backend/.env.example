# ========================================
# 鲜标智投 — 生鲜食材配送投标文件智能生成平台
# 后端环境变量配置模板
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# ========================================

# --- 应用配置 ---
APP_NAME="鲜标智投 — 生鲜食材配送投标文件智能生成平台"
APP_VERSION="1.0.0"
DEBUG=true
# 生成安全密钥：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY="dev-secret-key-for-local-testing-only-32chars!"
ACCESS_TOKEN_EXPIRE_MINUTES=120

# --- 数据库 (PostgreSQL 16 + pgvector) ---
# Docker 内部：postgres:5432  |  本地宿主机：localhost:5433
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5433/fresh_bid_platform"

# --- Redis Stack ---
REDIS_URL="redis://localhost:6380/0"

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# =====================================================
# AI / LLM 配置
# =====================================================

# --- 推荐方案 A: DeepSeek（国产合规，生产首选）---
# 优势：合规第一 + 成本最低(¥2/M tokens) + 中文商务文档能力强
# 申请地址：https://platform.deepseek.com/
# OPENAI_API_KEY="sk-你的DeepSeek密钥"
# OPENAI_BASE_URL="https://api.deepseek.com/v1"
# AI_MODEL="deepseek-chat"

# --- 备用方案 B: 通义千问（阿里云，备选/降级）---
# OPENAI_API_KEY="sk-你的通义千问密钥"
# OPENAI_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# AI_MODEL="qwen-max"

# --- 开发调试方案 C: Gemini（仅限本地开发，禁止生产使用）---
# ⚠️ 合规红线：Gemini为境外API，禁止在生产环境处理投标数据
OPENAI_API_KEY="你的Gemini-API-Key"
OPENAI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
AI_MODEL="gemini-2.5-flash"
GEMINI_API_KEY="你的Gemini-API-Key"

# --- LiteLLM 代理网关（可选，统一路由多模型）---
# LITELLM_BASE_URL="http://localhost:4000/v1"

# =====================================================
# 文件存储
# =====================================================
# 开发环境：使用本地 ./storage 目录
# 生产环境：推荐阿里云 OSS（中国境内节点）
# OSS_ENDPOINT="https://oss-cn-beijing.aliyuncs.com"
# OSS_ACCESS_KEY_ID=""
# OSS_ACCESS_KEY_SECRET=""
# OSS_BUCKET_NAME="fresh-bid-platform"

# =====================================================
# 投标业务配置
# =====================================================
# 报价下浮率合理区间
QUOTATION_MIN_DISCOUNT=0.05
QUOTATION_MAX_DISCOUNT=0.15
# 资质证书到期提前预警天数
CREDENTIAL_EXPIRY_WARN_DAYS=90

# =====================================================
# 管理员账号
# =====================================================
ADMIN_INIT_PASSWORD="admin123"

# =====================================================
# LangFuse 可观测性（可选，不配则静默跳过）
# =====================================================
# LANGFUSE_PUBLIC_KEY="pk-xxx"
# LANGFUSE_SECRET_KEY="sk-xxx"
# LANGFUSE_HOST="https://cloud.langfuse.com"
